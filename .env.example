# ═══════════════════════════════════════════════════════════════════
# .env — Baúl de credenciales para scripts y herramientas locales
# ═══════════════════════════════════════════════════════════════════
#
# CÓMO USAR:
#   1. Copiá este archivo:   cp .env.example .env
#   2. Rellená los valores reales en .env (NO en este ejemplo)
#   3. Restringí permisos:    chmod 600 .env
#
# IMPORTANTE: .env está en .gitignore — nunca se sube al repo.
# Este archivo (.env.example) sí se commitea: documenta qué claves
# existen, pero sin valores reales.
#
# Los scripts en scripts/ leen este archivo automáticamente.
# ═══════════════════════════════════════════════════════════════════

# ──────── Odoo Online ────────
ODOO_URL=https://paracarpinteros.odoo.com
ODOO_DB=paracarpinteros
ODOO_USERNAME=manelcomasbre@gmail.com
ODOO_API_KEY=

# ──────── Correos CR (Pymexpress) — credenciales del WS ────────
CORREOS_ENV=test
CORREOS_USERNAME=
CORREOS_PASSWORD=
CORREOS_USER_ID=
CORREOS_CODIGO_CLIENTE=

# ──────── GitHub ────────
# Token personal con permisos repo + issues:write (para monitor uptime, etc.)
GITHUB_TOKEN=

# ──────── Cloudflare ────────
# API token con permisos sobre la zona del dominio
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ──────── Alibaba / proveedores ────────
# Espacio para tokens de portales de proveedores si en algún momento hacen falta
ALIBABA_API_KEY=

# ──────── Otros ────────
# Añadí aquí cualquier otra credencial que vayas necesitando.
# Formato: NOMBRE_VARIABLE=valor (sin espacios alrededor del =)
